(let
    (
        (ref-coin:module{stoa-ns.stoic-fungible-v1} coin)
        (ref-DALOS:module{OuronetDalosV1} DALOS)
        (ref-DPTF:module{DemiourgosPactTrueFungibleV1} DPTF)
        (ref-ATS:module{AutostakeV1} ATS)
        (ref-TS01-C1:module{TalosStageOne_ClientOneV1} TS01-C1)
        (ref-TS01-C2:module{TalosStageOne_ClientTwoV1} TS01-C2)
        ;;
        (patron:string "Ѻ.éXødVțrřĄθ7ΛдUŒjeßćιiXTПЗÚĞqŸœÈэαLżØôćmч₱ęãΛě$êůáØCЗшõyĂźςÜãθΘзШË¥şEÈnxΞЗÚÏÛjDVЪжγÏŽнăъçùαìrпцДЖöŃȘâÿřh£1vĎO£κнβдłпČлÿáZiĐą8ÊHÂßĎЩmEBцÄĎвЙßÌ5Ï7ĘŘùrÑckeñëδšПχÌàî")
        (liquid-sc:string (ref-DALOS::GOV|LIQUID|SC_NAME))
        (treasury-sc:string (ref-DALOS::GOV|DHV2|SC_NAME))
        (standard-treasury-sc:string (ref-DALOS::GOV|DHV1|SC_NAME))
        (ats-sc:string (ref-DALOS::GOV|ATS|SC_NAME))
        (wstoa:string (ref-DALOS::UR_WrappedStoaID))
        (sstoa:string (ref-DALOS::UR_SilverStoaID))
        (gstoa:string (ref-DALOS::UR_GoldenStoaID))
        (SilverStoaPillar:string "SilverStoaPillar-O136CBn22ncY")
        (GoldenStoaPillar:string "GoldenStoaPillar-O136CBn22ncY")
        ;;
        (genesis-wstoa:decimal 4603561.053853957254)                                            ;;Exact Kadena Ouronet WrappedKadena Supply
        (genesis-silverstoa:decimal 891186.381030003138205971991574)                            ;;Exact Kadena Ouronet Liquid Kadena Supply
        (genesis-silverstoapillar-resident-wstoa:decimal 1786946.765064640491)                  ;;Exact Kadena Ouronet LiquidKadenaIndex Resident WKDA Value
        (genesis-goldenstoa:decimal 191536.563207343411211223183977)                            ;;Exact Kadena Ouronet Pension Kadena Supply
        (genesis-goldenstoapillar-resident-silverstoa:decimal 518807.512234466846508781332894)  ;;Exact Kadena Ouronet KORIndex Resident LKDA Value
        (genesis-goldenstoapillar-royalty-silverstoa:decimal 5331.130953982599809150257079)     ;;Exact Kadena Ouronet KORIndex Royalty LKDA Value
    )
    [
        ;;[1]Premine WSTOA
        (ref-TS01-C1::DPTF|C_Mint
            patron
            wstoa
            liquid-sc
            genesis-wstoa
            false
        )
        ;;[2]   Kickstart SilverStoaPillar with exact same Index on Kadena Ouronet
        ;;[2.1] First move <genesis-wstoa> to Standard Treasury
        (ref-TS01-C1::DPTF|C_Transfer 
            patron 
            wstoa
            liquid-sc
            standard-treasury-sc 
            genesis-wstoa
            true
        )
        ;;[2.2] Kickstarts the SilverStoaPillar Autostake Pool
        (ref-TS01-C2::ATS|C_KickStart
            patron
            standard-treasury-sc
            SilverStoaPillar
            [genesis-silverstoapillar-resident-wstoa]
            genesis-silverstoa
        )
        ;;[3]   Kickstart GoldenStoaPillar with exact same Index on Kadena Ouronet
        (ref-TS01-C2::ATS|C_KickStart
            patron
            standard-treasury-sc
            GoldenStoaPillar
            [genesis-goldenstoapillar-resident-silverstoa]
            genesis-goldenstoa
        )
        ;;[3.1] ProperlySet the Royalty amount in the GoldenStoaPillar
        (ref-TS01-C1::DPTF|C_Transfer 
            patron
            sstoa
            standard-treasury-sc
            ats-sc
            genesis-goldenstoapillar-royalty-silverstoa
            true
        )
        (acquire-module-admin ATS)
        (with-capability (ATS.SECURE)
            (ref-ATS::XE_UpdateRUR 
                GoldenStoaPillar
                sstoa
                3
                true
                genesis-goldenstoapillar-royalty-silverstoa
            )
        )
        (ref-ATS::UR_RewardTokenRUR GoldenStoaPillar 3)
        ;;[4] Checks Remaining amounts
        (format "Standard Treasury has left {} Wrapped, {} SilverStoa and {} Golden Stoa."
            [
                (ref-DPTF::UR_AccountSupply wstoa standard-treasury-sc)
                (ref-DPTF::UR_AccountSupply sstoa standard-treasury-sc)
                (ref-DPTF::UR_AccountSupply gstoa standard-treasury-sc)
            ]
        )
        ;;5] Fuels Autonomous Liquid Account to cover for the existance of WSTOA with native stoa, using Foundation account
        (ref-coin::C_Transmit "stoa-foundation" (ref-DALOS::UR_AccountKadena liquid-sc) genesis-wstoa)
    ]
)

(coin.C_Transmit "stoa-foundation" )

1786946.765064640491000000000000
;;891186.381030003138205971991574 LKDA supply


(namespace "ouronet-ns")
(let
    (
        (ref-DALOS:module{OuronetDalosV1} DALOS)
        (ref-TS01-C1:module{TalosStageOne_ClientOneV1} TS01-C1)
        (ref-TS01-C2:module{TalosStageOne_ClientTwoV1} TS01-C2)
        ;;
        (patron:string "Ѻ.éXødVțrřĄθ7ΛдUŒjeßćιiXTПЗÚĞqŸœÈэαLżØôćmч₱ęãΛě$êůáØCЗшõyĂźςÜãθΘзШË¥şEÈnxΞЗÚÏÛjDVЪжγÏŽнăъçùαìrпцДЖöŃȘâÿřh£1vĎO£κнβдłпČлÿáZiĐą8ÊHÂßĎЩmEBцÄĎвЙßÌ5Ï7ĘŘùrÑckeñëδšПχÌàî")
        (standard-treasury-sc:string (ref-DALOS::GOV|DHV1|SC_NAME))
        (treasury-sc:string (ref-DALOS::GOV|DHV2|SC_NAME))
        ;;
        (ouro:string (ref-DALOS::UR_OuroborosID))
        (ignis:string (ref-DALOS::UR_IgnisID))
        (auryn:string (ref-DALOS::UR_AurynID))
        (eliteauryn:string (ref-DALOS::UR_EliteAurynID))
        (Auryndex:string "Auryndex-O136CBn22ncY")
        (EliteAuryndex:string "EliteAuryndex-O136CBn22ncY")
        (genesis-ourobors:decimal 2000000.0)                                            ;;Only for premine - excess is burned
        (genesis-ignis-gas:decimal 1197646.0)                                           ;;Exact Kadena Ouronet Gas Supply
        (genesis-auryn:decimal 491200.497868436990854395195954)                         ;;Exact Kadena Ouronet Auryn Supply
        (genesis-eliteauryn:decimal 385464.817368595888903539337331)                    ;;Exact Kadena Ouronet EliteAuryn Supply
        (genesis-auryndex-resident-ouro:decimal 1438411.507485691412488618573213)       ;;Exact Kadena Ouronet Auryndex Resident Ouro Value
        (genesis-eliteauryndex-resident-auryn:decimal 445562.352902725837021763757679)  ;;Exact Kadena Ouronet Auryndex Resident Auryn Value

    )
    [
        ;;[1] Premine Ouroboros
        (ref-TS01-C1::DPTF|C_Mint
            patron
            ouro
            treasury-sc
            genesis-ourobors
            true
        )
        ;;[2] Premine Ignis Gas
        (ref-TS01-C1::DPTF|C_Mint
            patron
            ignis
            treasury-sc
            genesis-ignis-gas
            true
        )
        ;;[2]   Kickstart Auryndex with exact same Index on Kadena Ouronet
        ;;[2.1] First Move <genesis-auryndex-resident-ouro> to Standard Treasury
        (ref-TS01-C1::DPTF|C_Transfer 
            patron 
            ouro 
            treasury-sc 
            standard-treasury-sc 
            genesis-auryndex-resident-ouro
            false
        )
        ;;[2.2] Only a Standard Ouronet Account can kickstart an Autostake Pool
        ;;      Kickstarts the Auryndex Autostake Pool
        (ref-TS01-C2::ATS|C_KickStart
            patron
            standard-treasury-sc
            Auryndex
            [genesis-auryndex-resident-ouro]
            genesis-auryn
        )
        ;;[3]   Kickstarts EliteAuryndex with exact same Index on Kadena Ouronet
        ;;      Uses Auryn now existing on <standard-treasury-sc>
        (ref-TS01-C2::ATS|C_KickStart
            patron
            standard-treasury-sc
            EliteAuryndex
            [genesis-eliteauryndex-resident-auryn]
            genesis-eliteauryn
        )
        ;;[4] Moves remaining Auryn and generated EliteAuryn back to <treasury-sc>
        (ref-TS01-C1::DPTF|C_MultiTransfer
            patron
            [auryn eliteauryn]
            standard-treasury-sc
            treasury-sc
            [(- genesis-auryn genesis-eliteauryndex-resident-auryn) genesis-eliteauryn]
            true
        )
    ]
)

