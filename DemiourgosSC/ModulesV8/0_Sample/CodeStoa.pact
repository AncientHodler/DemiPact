        (ref-TS01-C3:module{TalosStageOne_ClientThreeV2} TS01-C3)
        ;;
        (patron:string "Ѻ.éXødVțrřĄθ7ΛдUŒjeßćιiXTПЗÚĞqŸœÈэαLżØôćmч₱ęãΛě$êůáØCЗшõyĂźςÜãθΘзШË¥şEÈnxΞЗÚÏÛjDVЪжγÏŽнăъçùαìrпцДЖöŃȘâÿřh£1vĎO£κнβдłпČлÿáZiĐą8ÊHÂßĎЩmEBцÄĎвЙßÌ5Ï7ĘŘùrÑckeñëδšПχÌàî")
        (treasury-sc:string (ref-DALOS::GOV|DHV2|SC_NAME))
        (custodians:string "Ѻ.Щę7ãŽÓλ4ěПîЭđЮЫAďбQOχnиИДχѺNŽł6ПžιéИąĞuπЙůÞ1ęrПΔżæÍžăζàïαŮŘDzΘ€ЦBGÝŁЭЭςșúÜđŻõËŻκΩÎzŁÇÉΠмłÔÝÖθσ7₱в£μŻzéΘÚĂИüyćťξюWc2И7кςαTnÿЩE3MVTÀεPβafÖôoъBσÂбýжõÞ7ßzŁŞε0âłXâÃЛ")
        (dev-funds:string "Ѻ.CЭΞŸNGúůρhãmИΘÛ¢₳šШдìAÚwŚGýηЗПAÊУÔȘřŽÍζЗηmΔφDmcдΛъ₳tĂýăŮsПÞ$öœGθeBŽvąαÃfçл¢ĎĆď$şbsЦэΘNÄëÍĂνуãöž¥àZjÆůšÁœôñχŽâЩåτâн4μфAOçĎΓuЗŮnøЙãĚè6Дżîþż$цÑûρψŻïZÉλûæřΨeèÎígςeL")
        (standard-treasury-sc:string (ref-DALOS::GOV|DHV1|SC_NAME))
        (swp-sc:string (ref-DALOS::GOV|SWP|SC_NAME))
        ;;
        (sstoa:string (ref-DALOS::UR_SilverStoaID))
        (ouro:string (ref-DALOS::UR_OuroborosID))
        (wstoa:string (ref-DALOS::UR_WrappedStoaID))
        ;;
        (primal-pool-silverstoa-supply:decimal 284543.038641077349893748760223)
        (primal-pool-ouroboros-supply:decimal 128309.929351919560523509823523)
        (primal-pool-wrappedstoa-supply:decimal 359375.374620604945000000000000)
        (genesis-lp-supply:decimal 217067137.497873868259961719899832)
    )
    [
        ;;[0] Move Tokens from to patron
        (ref-TS01-C1::DPTF|C_Transfer 
            patron 
            ouro
            treasury-sc
            patron 
            primal-pool-ouroboros-supply
            false
        )
        (ref-TS01-C1::DPTF|C_Transfer 
            patron 
            sstoa
            standard-treasury-sc
            treasury-sc
            primal-pool-silverstoa-supply
            true
        )
        (ref-TS01-C1::DPTF|C_Transfer 
            patron 
            sstoa
            treasury-sc
            patron
            primal-pool-silverstoa-supply
            false
        )
        (ref-TS01-C1::DPTF|C_Transfer 
            patron 
            wstoa
            standard-treasury-sc
            patron
            primal-pool-wrappedstoa-supply
            false
        )
        (let
            (
                (issue-output:list
                    ;;[1] Issue SWP Pair
                    (ref-TS01-C3::SWP|C_IssueWeighted
                        patron
                        patron
                        [
                            { "token-id":  sstoa, "token-supply": primal-pool-silverstoa-supply}
                            { "token-id":  ouro, "token-supply": primal-pool-ouroboros-supply}
                            { "token-id":  wstoa, "token-supply": primal-pool-wrappedstoa-supply}
                        ]
                        2.5
                        [0.3 0.5 0.2]
                        true
                    )
                )
                (swpair:string (at 0 issue-output))
                (lp-id:string (at 1 issue-output))
            )
            [
                ;;Setup SWP Enviroment
                (ref-TS01-A::SWP|A_UpdateLiquidBoost true)
                (ref-TS01-A::SWP|A_DefinePrimordialPool swpair)
                (ref-TS01-A::SWP|A_ToggleAsymetricLiquidityAddition true)
                ;;Setup <swpair>
                (ref-TS01-C3::SWP|C_UpdateFee
                    patron
                    swpair
                    5.0
                    false
                )
                (ref-TS01-C3::SWP|C_UpdateSpecialFeeTargets
                    patron
                    swpair
                    [
                        {"target":standard-treasury-sc,     "value":16}
                        {"target":custodians,               "value":32}
                        {"target":dev-funds,                "value":16}
                    ]
                )
                (ref-TS01-C3::SWP|C_ToggleAddLiquidity patron swpair true)
                (ref-TS01-C3::SWP|C_ToggleSwapCapability patron swpair true)
                ;;Mint remaining LP Tokens and distribute them to their owners
                (ref-TS01-C1::DPTF|C_Mint
                    patron
                    lp-id
                    swp-sc
                    (- genesis-lp-supply 10000000.0)
                    false
                )
                (ref-TS01-C1::DPTF|C_BulkTransfer
                    patron
                    lp-id
                    swp-sc
                    [
                      "Ѻ.ÁΛȚçqÂélπ∇StÁĐѺщEzφ$äЦEИБďËц0qεÍțGĞфhȘЬ3DĂШœшβÑЯĂçcA6ĘnЙΓĆyЮèymÿ₱XRÚнDâãнΣÖrŘμαфßŚÍÕȘÄ3ÊäŤжъUИЪ4ŻыDõíжAж5zůιÜĎиžQЖAwĐxçÖźЩÀμ₳ŘÜтšPŘζÈëШБØπąuыüÚähŸÏÚΞκĚбËŠÓéÃвЭЧ"
                      "Ѻ.ĄÀтмωωàŹČлďÜhÍηЛνÙνûĘõțЫåÒÛHážNÍЧψξïžŹЬΛξП¥ЮςĄEйNĄЧ9óпиÃЗ2äÔвœ₿£ČóΩÞдréě7νшDÅЬXтBørŸĂBςąЙęìvÆлμЛáΩγĘЗôåУțτжéδÚνpÍżȘĘï4ąŹȘkφNθþÀωΞÀWžIи5ь€ÊOôΣëñэÔÿνÜw1юÔzźцξńѺfś"
