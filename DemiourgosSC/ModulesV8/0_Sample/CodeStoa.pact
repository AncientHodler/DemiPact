    (fold
        (lambda (acc:[string] account:string)
            (let
                (
                    (coding-division:[integer] (ref-DPDC::URD_AccountNonces account DHCD true))
                    (coding-division-supplies:[integer] (ref-DPDC::UR_AccountNoncesSupplies account DHCD true coding-division))
                    (custodians:[integer] (ref-DPDC::URD_AccountNonces account DHOC true))
                    (custodians-supplies:[integer] (ref-DPDC::UR_AccountNoncesSupplies account DHOC true custodians))
                    (wonder-coach:[integer] (ref-DPDC::URD_AccountNonces account DHWC true))
                    (wonder-coach-supplies:[integer] (ref-DPDC::UR_AccountNoncesSupplies account DHWC true wonder-coach))
                    (company-shares:[integer] (ref-DPDC::URD_AccountNonces account DH true))
                    (company-shares-supplies:[integer] (ref-DPDC::UR_AccountNoncesSupplies account DH true company-shares))
                    (bloodshed:[integer] (ref-DPDC::URD_AccountNonces account DHB false))
                    (nosferatu:[integer] (ref-DPDC::URD_AccountNonces account DHN false))
                    (bunnies:[integer] (ref-DPDC::URD_AccountNonces account KBN false))
                )
                (+ acc
                    [
                        (format "Scanned Account: {}" [account])
                        (format "Owned Coding Division Nonces are: {}, and their supplies are {}" [coding-division coding-division-supplies])
                        (format "Owned Ouronet Custodian Nonces are: {}, and their supplies are {}" [custodians custodians-supplies])
                        (format "Owned Wonder-Coach Nonces are: {}, and their supplies are {}" [wonder-coach wonder-coach-supplies])
                        (format "Owned Company-Shares Nonces are: {}, and their supplies are {}" [company-shares company-shares-supplies])
                        (format "Owned Bloodshed Nonces are: {}" [bloodshed])
                        (format "Owned Nosferatu Nonces are: {}" [nosferatu])
                        (format "Owned Bunnies Nonces are: {}" [bunnies])
                    ]
                )
            )
        )
        []
        keyz
    )
)


