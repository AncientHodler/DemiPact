        (keyz:[string] [(at 11 accounts)])
        (DHCD:string "DHCD-5JAYtPyKLjAo")   ;;Coding Division
        (DHOC:string "DHOC-ti-pZVMLvMlA")	;;Ouronet Custodians
        (DHWC:string "DHWC-u3x0_e0z8sZi")	;;Wonder Coach
        (DH:string "E|DH-m4hoGF0ngNxa")		;;Demiourgos Holdings Company Shares
        (DHB:string "DHB-vQePGHkCAkR1")		;;Bloodshed
        (DHN:string "DHN-vQePGHkCAkR1")		;;Nosferatu
        (KBN:string "KBN-vQePGHkCAkR1")		;;Bunnies
