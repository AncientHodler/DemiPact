(let
    (
        (ref-DALOS:module{OuronetDalosV1} DALOS)
        (ref-U|G:module{OuronetGuardsV1} U|G)
        (ref-P|DPAD:module{OuronetPolicyV1} DEMIPAD)
        (ref-P|SPAY:module{OuronetPolicyV1} DEMIPAD-STOICPAY)
        (ref-P|STOAICO:module{OuronetPolicyV1} STOAICO)
        (ref-TS01-C1:module{TalosStageOne_ClientOneV1} TS01-C1)
        (ref-DPAD:module{DemiourgosLaunchpadV1} DEMIPAD)
        (mg:guard (create-capability-guard (TS02-DPAD.P|TALOS-SUMMONER)))
        (lpad-sc:string (ref-DPAD::GOV|DEMIPAD|SC_NAME))
        (patron:string "Ѻ.éXødVțrřĄθ7ΛдUŒjeßćιiXTПЗÚĞqŸœÈэαLżØôćmч₱ęãΛě$êůáØCЗшõyĂźςÜãθΘзШË¥şEÈnxΞЗÚÏÛjDVЪжγÏŽнăъçùαìrпцДЖöŃȘâÿřh£1vĎO£κнβдłпČлÿáZiĐą8ÊHÂßĎЩmEBцÄĎвЙßÌ5Ï7ĘŘùrÑckeñëδšПχÌàî")
    )
    [
        ;;Backward IMC
        (ref-P|STOAICO::P|A_Define)
        ;;Forward IMC
        (ref-P|SPAY::P|A_AddIMP mg)
        (ref-P|STOAICO::P|A_AddIMP mg)
        (ref-TS01-C1::DALOS|C_RotateGovernor
            patron
            lpad-sc
            (ref-U|G::UEV_GuardOfAny
                [
                    (create-capability-guard (DEMIPAD.DEMIPAD|GOV))
                    (ref-P|DPAD::P|UR "SPARK|RemoteGov")
                    (ref-P|DPAD::P|UR "SNAKES|RemoteGov")
                    (ref-P|DPAD::P|UR "CUSTODIANS|RemoteGov")
                    (ref-P|DPAD::P|UR "KPAY|RemoteGov")
                    (ref-P|DPAD::P|UR "STOAICO|RemoteGov")
                ]
            )
        )
        (let
            (
                (wstoa-id:string (ref-DALOS::UR_WrappedStoaID))
                (stoa-ico-ids:list
                    (STOAICO.A_InitialiseDistributionVault patron)
                )
                (wurstoa-id:string (at 0 stoa-ico-ids))
                (vusd-id:string (at 1 stoa-ico-ids))
            )
            [
                (format 
                    "StoaICO Distribution Vault initialise correctly, with Token IDs {} {} {}" 
                    [wstoa-id wurstoa-id vusd-id]
                )
                (acquire-module-admin DALOS)
                (update ref-DALOS::DALOS|PropertiesTable DALOS.DALOS|INFO
                    {"ur-stoa-id"   : wurstoa-id}
                )
                (STOAICO.A_Stake patron patron 120.0)
                (STOAICO.A_Unstake patron patron 120.0)
            ]
        )    
    ]
)



