(let
    (
        (ref-U|LST:module{StringProcessor} U|LST)
        ;(ref-DALOS:module{OuronetDalosV6} DALOS)
        (ref-DPTF:module{DemiourgosPactTrueFungibleV8} DPTF)
        (keyz:[string] (keys DALOS.DALOS|AccountTable))
        (leng:integer (length keyz))
        (values:[decimal]
            (fold
                (lambda
                    (acc:[decimal] idx:integer)
                    (ref-U|LST::UC_AppL acc (ref-DPTF::UR_AccountSupply "KPAY-8ogtqXeTmcSe" (at idx keyz)))
                )
                []
                (enumerate 0 (- leng 1))
            )
        )
        (folded-obj:[object]
            (fold
                (lambda
                    (acc:[object] idx:integer)
                    (+ acc
                        [{"account": (at idx keyz),
                          "supply": (at idx values)}])
                )
                []
                (enumerate 0 (- leng 1))
            )
        )
    )
    (sort ["supply"] folded-obj)
)


